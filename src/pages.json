{
  "darkmode": true,
  "themeLocation": "theme.json",
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "雅刷"
      }
    },
    {
      "path": "pages/library/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "题库管理"
      }
    },
    {
      "path": "pages/quiz/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "刷题"
      }
    },
    {
      "path": "pages/wrong/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "错题本"
      }
    },
    {
      "path": "pages/wrong/detail",
      "style": {
        "navigationBarTitleText": "错题详情",
        "navigationBarBackgroundColor": "@navBgColor"
      }
    },
    {
      "path": "pages/settings/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "设置"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "@navTextColor",
    "navigationBarTitleText": "雅刷",
    "navigationBarBackgroundColor": "@navBgColor",
    "backgroundColor": "@bgColor"
  },
  "tabBar": {
    "color": "@tabBarColor",
    "selectedColor": "@tabBarSelectedColor",
    "borderStyle": "black",
    "backgroundColor": "@tabBarBgColor",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页"
      },
      {
        "pagePath": "pages/library/index",
        "text": "题库"
      },
      {
        "pagePath": "pages/wrong/index",
        "text": "错题"
      },
      {
        "pagePath": "pages/settings/index",
        "text": "设置"
      }
    ]
  }
}
